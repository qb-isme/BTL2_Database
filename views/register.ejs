<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng ký | EduManage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f7f6; padding: 40px 0; font-family: 'Segoe UI', sans-serif;}
        .reg-card { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); max-width: 800px; margin: auto; }
        .form-label { font-weight: 600; color: #4b5563; font-size: 0.9rem; }
    </style>
</head>
<body>
    <div class="container">
        <div class="reg-card">
            <div class="text-center mb-4">
                <h3 class="fw-bold text-primary">Tạo tài khoản học viên</h3>
                <p class="text-muted">Tham gia cùng hàng ngàn học viên khác trên EduManage</p>
            </div>
            
            <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
            
            <form action="/register" method="POST" class="row g-3">
                <h6 class="text-primary border-bottom pb-2 mt-4">Thông tin đăng nhập</h6>
                <div class="col-md-6"><label class="form-label">Tên đăng nhập *</label><input type="text" name="username" class="form-control" required></div>
                <div class="col-md-6"><label class="form-label">Mật khẩu *</label><input type="password" name="password" class="form-control" required></div>
                
                <h6 class="text-primary border-bottom pb-2 mt-4">Thông tin cá nhân</h6>
                <div class="col-md-6"><label class="form-label">Họ và Tên *</label><input type="text" name="hoten" class="form-control" required></div>
                <div class="col-md-6"><label class="form-label">Email</label><input type="email" name="email" class="form-control"></div>
                <div class="col-md-4"><label class="form-label">Số điện thoại</label><input type="text" class="form-control" name="sdt" pattern="[0-9]{10}" maxlength="10" title="Vui lòng nhập đúng 10 chữ số" required></div>
                <div class="col-md-4"><label class="form-label">Ngày sinh</label><input type="date" name="ngaysinh" class="form-control"></div>
                <div class="col-md-4"><label class="form-label">Giới tính</label>
                    <select name="gioitinh" class="form-select"><option value="Nam">Nam</option><option value="Nữ">Nữ</option></select>
                </div>
                
                <h6 class="text-primary border-bottom pb-2 mt-4">Địa chỉ liên hệ</h6>
                <div class="col-md-4"><label class="form-label">Tỉnh / Thành phố</label><input type="text" name="city" class="form-control"></div>
                <div class="col-md-4"><label class="form-label">Quận / Huyện</label><input type="text" name="quan" class="form-control"></div>
                <div class="col-md-4"><label class="form-label">Đường / Số nhà</label><input type="text" name="duong" class="form-control"></div>
                
                <div class="col-12 mt-4">
                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold" style="background-color: #2e4a9e;">ĐĂNG KÝ TÀI KHOẢN</button>
                </div>
            </form>
            <div class="text-center mt-4">
                Đã có tài khoản? <a href="/login" class="fw-bold text-decoration-none">Đăng nhập</a>
            </div>
        </div>
    </div>
</body>
</html>