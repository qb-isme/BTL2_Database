<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đăng nhập | EduManage</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <style>
        body { background-color: #f4f7f6; display: flex; align-items: center; justify-content: center; height: 100vh; font-family: 'Segoe UI', sans-serif;}
        .login-card { background: white; padding: 40px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); width: 100%; max-width: 400px; }
        .btn-login { background-color: #2e4a9e; color: white; border-radius: 6px; padding: 10px; font-weight: bold; width: 100%; margin-top: 10px;}
        .btn-login:hover { background-color: #1e3a8a; color: white; }
        
        /* CSS làm mờ các dấu chấm ở ô nhập liệu */
        .form-control::placeholder {
            color: #adb5bd !important; 
            opacity: 0.6 !important;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <h2 class="fw-bold" style="color: #1e3a8a;"><i class="fa-solid fa-graduation-cap me-2"></i>EduManage</h2>
            <p class="text-muted">Đăng nhập vào hệ thống</p>
        </div>
        
        <% if (error) { %>
            <div class="alert alert-danger text-center py-2"><%= error %></div>
        <% } %>
        
        <form action="/login" method="POST">
            <div class="mb-3">
                <label class="form-label fw-bold text-secondary">Tên đăng nhập</label>
                <input type="text" name="username" class="form-control" placeholder="VD: teacher_john" required>
            </div>
            <div class="mb-4">
                <label class="form-label fw-bold text-secondary">Mật khẩu</label>
                <input type="password" name="password" class="form-control" placeholder="••••••••" required>
            </div>
            <button type="submit" class="btn btn-login">ĐĂNG NHẬP</button>
        </form>
        
        <div class="text-center mt-3">
            <!-- Nút chuyển sang trang Đăng ký -->
            <p class="mb-2 small">Chưa có tài khoản? <a href="/register" class="text-primary fw-bold text-decoration-none">Đăng ký ngay</a></p>
            <a href="/" class="text-decoration-none text-muted small">← Quay lại trang chủ</a>
        </div>
    </div>
</body>
</html>